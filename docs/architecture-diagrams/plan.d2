desired_plots: {
	label: "Target plots"
	"Psychometric function": {
    link: "layers.psychometric-function"
    schema: {
      label: "Observed psychometric data"
      shape: sql_table
      magnitude: float
      hit_rate: float
      n_trials: int
    }
    type: scatter
  }
}


data_model: {
  label: "Data model"
  trials_schema: {
    shape: sql_table
    label: "Trials"
    magnitude: float
    result: bool
  }

}

data_model.trials_schema -> desired_plots."Psychometric function"
